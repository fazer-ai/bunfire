{
  "name": "bunfire",
  "version": "0.0.0",
  "private": true,
  "module": "src/index.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/fazer-ai/bunfire.git"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "test": "bun test --coverage",
    "test-watch": "bun test --watch",
    "lint": "bun biome check --error-on-warnings",
    "format": "bun biome check --write",
    "build-check": "bunx tsc --noEmit",
    "setup": "bun ./scripts/setup.ts",
    "set-admin": "bun scripts/set-admin.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "i18n:extract": "i18next 'src/client/**/*.{ts,tsx}' --config i18next-parser.config.cjs && i18next 'src/api/**/*.ts' --config i18next-parser.api.config.cjs",
    "check": "bun run lint && bun run build-check && bun run i18n:extract && bun run test",
    "prepare": "husky"
  },
  "dependencies": {
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.9",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/static": "^1.4.9",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bun-plugin-tailwind": "^0.1.2",
    "elysia": "^1.4.28",
    "elysia-helmet": "^3.1.0",
    "elysia-rate-limit": "^4.5.1",
    "i18next": "^26.0.4",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.2",
    "react-router": "^7.14.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@cloudflare/workers-types": "^4.20260411.1",
    "@happy-dom/global-registrator": "^20.8.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "husky": "^9.1.7",
    "i18next-parser": "^9.4.0",
    "pino-caller": "^4.0.0",
    "prisma": "^7.7.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
