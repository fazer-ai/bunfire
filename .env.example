NODE_ENV=development
PORT=3000
PUBLIC_URL=http://localhost:${PORT}
LOG_LEVEL=info

JWT_SECRET=change-me-in-production
ENCRYPTION_KEY=change-me-in-production
CORS_ORIGIN=localhost:${PORT}

# NOTE: Separate the port variable to allow overriding in docker-compose
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:postgres@localhost:${POSTGRES_PORT}/bunfire_db

# NOTE: Server-side CDN URL for backend use (e.g. constructing absolute asset URLs in emails)
CDN_URL=${PUBLIC_URL}

# NOTE: Public env vars are exposed to the frontend via BUN_PUBLIC_ prefix
BUN_PUBLIC_CDN_URL=${CDN_URL}

# NOTE: Optional Google Sign-In via Google Identity Services (GIS). Leave empty to disable.
# Create an OAuth 2.0 Client ID (Web application) at https://console.cloud.google.com/apis/credentials
# Add your Authorized JavaScript origins (e.g. http://localhost:3000 in dev, https://yourdomain in prod).
# Client secret is NOT required; the backend verifies the ID token against Google's JWKS.
GOOGLE_CLIENT_ID=

# NOTE: Optional comma-separated list of email domains allowed to register new accounts.
# Leave empty to allow any domain. Applies to both email/password signup and Google OAuth
# first-time sign-in. Does not affect existing users or account linking.
# Example: ALLOWED_SIGNUP_DOMAINS=example.com,mycompany.io
ALLOWED_SIGNUP_DOMAINS=

# NOTE: Optional comma-separated list of email domains whose new accounts are auto-promoted
# to ADMIN on signup. Leave empty for no auto-promotion (the default). Auto-promotion only
# fires for verified channels (Google first-time sign-in with email_verified=true). Plain
# email/password signups are always created as USER even when the domain matches, because
# there is no proof the registrant controls the address. Promote password accounts manually
# with `bun set-admin <email>`. Existing users are not affected.
#
# THREAT MODEL: Anyone who can obtain a Google ID token with email_verified=true for a
# listed domain will receive ADMIN on first sign-in. That includes any Google Workspace
# admin (who can provision arbitrary @yourdomain addresses), any insider with a legitimate
# account, anyone who compromises Workspace admin credentials or DNS, and anyone who
# exploits a Google provisioning bug. "Control of an email address" is NOT the same as
# "entitled to ADMIN in this app". Only enable this if the Workspace controlling the
# domain is operated by the same group that should have admin control over this app.
# Otherwise leave empty and promote admins explicitly with `bun set-admin`.
# Example: ADMIN_SIGNUP_DOMAINS=mycompany.io
ADMIN_SIGNUP_DOMAINS=
